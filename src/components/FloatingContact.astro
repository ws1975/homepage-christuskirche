---
interface Props {
  phone: string;
  email: string;
  mapHref: string;
}

const { phone, email, mapHref } = Astro.props;
---

<div class="floating-contact" aria-label="Schnellkontakt">
  <a href={`mailto:${email}`} aria-label="E-Mail schreiben">E-Mail</a>
  <a href={`tel:${phone.replace(/\s+/g, "")}`} aria-label="Anrufen">Telefon</a>
  <a href={mapHref} aria-label="Standort öffnen">Standort</a>
</div>

<a class="floating-contact-mobile" href="/kontakt/">Kontakt</a>

<style>
  .floating-contact {
    position: fixed;
    right: 1.25rem;
    top: 50%;
    z-index: 16;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transform: translateY(-50%);
  }

  .floating-contact a,
  .floating-contact-mobile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 7rem;
    min-height: 3rem;
    padding: 0.7rem 0.9rem;
    border-radius: 999px;
    text-decoration: none;
    backdrop-filter: blur(14px);
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(23, 48, 66, 0.1);
    box-shadow: 0 16px 36px rgba(24, 41, 53, 0.12);
    color: #173042;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .floating-contact-mobile {
    display: none;
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 16;
    min-width: auto;
    padding-inline: 1.15rem;
  }

  @media (max-width: 1100px) {
    .floating-contact {
      display: none;
    }

    .floating-contact-mobile {
      display: inline-flex;
    }
  }
</style>
