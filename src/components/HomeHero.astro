---
import { formatEventDate, formatEventTime } from "../lib/events";

interface EventData {
  title: string;
  start: Date;
  location: string;
  audience?: string;
}

interface Props {
  title: string;
  subtitle: string;
  text: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
  image: string;
  imageAlt: string;
  nextService?: {
    data: EventData;
  };
}

const {
  title,
  subtitle,
  text,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  image,
  imageAlt,
  nextService,
} = Astro.props;
---

<section class="home-hero">
  <div class="shell hero-shell">
    <div class="hero-copy">
      <p class="eyebrow">Digitaler Empfang</p>
      <h1>{title}</h1>
      <p class="subtitle">{subtitle}</p>
      <p class="hero-text">{text}</p>

      <div class="button-row hero-actions">
        <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>
        <a class="button button-secondary" href={secondaryHref}>
          {secondaryLabel}
        </a>
      </div>

      <ul class="trust-list" aria-label="Schnelle Einstiege">
        <li>Sonntag 10:10 Uhr schnell finden</li>
        <li>Hilfe, Kontakt und Seelsorge direkt erreichbar</li>
        <li>Gemeindeleben ohne Umwege entdecken</li>
      </ul>
    </div>

    <div class="hero-visual-wrap">
      <figure class="hero-visual">
        <img src={image} alt={imageAlt} />
      </figure>

      <div class="hero-note">
        <strong>Bildhinweis</strong>
        <span>Aktuell Platzhalter. Später durch ein warmes Gemeindefoto mit echten Menschen ersetzen.</span>
      </div>

      {nextService && (
        <aside class="hero-service">
          <p class="hero-service-label">Nächster Gottesdienst</p>
          <h2>{nextService.data.title}</h2>
          <p>
            {formatEventDate(nextService.data.start)}
            <br />
            {formatEventTime(nextService.data.start)} Uhr
          </p>
          <p>{nextService.data.location}</p>
        </aside>
      )}
    </div>
  </div>
</section>

<style>
  .home-hero {
    position: relative;
    padding: 2.75rem 0 2rem;
    overflow: clip;
  }

  .home-hero::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 82%;
    background:
      radial-gradient(circle at top left, rgba(227, 189, 138, 0.2), transparent 38%),
      linear-gradient(135deg, #f6efe6 0%, #f7f3ed 38%, #fcfbf8 100%);
    pointer-events: none;
  }

  .hero-shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 2.5rem;
    align-items: center;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    padding: 1rem 0;
  }

  .hero-copy h1 {
    margin: 0;
    font-size: clamp(3rem, 6vw, 5.6rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
    max-width: 10ch;
    color: #173042;
  }

  .subtitle {
    margin: 1rem 0 0;
    font-size: clamp(1.2rem, 2.2vw, 1.8rem);
    color: #42606e;
  }

  .hero-text {
    max-width: 36rem;
    margin: 1rem 0 0;
    color: #5d7178;
    font-size: 1.08rem;
  }

  .hero-actions {
    margin-top: 1.5rem;
  }

  .trust-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
  }

  .trust-list li {
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(23, 48, 66, 0.08);
    box-shadow: 0 14px 30px rgba(20, 32, 45, 0.06);
    color: #35505b;
    font-size: 0.96rem;
  }

  .hero-visual-wrap {
    position: relative;
    min-height: 100%;
  }

  .hero-visual {
    margin: 0;
    border-radius: 32px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(24, 41, 53, 0.14);
    background: #ebe7e0;
  }

  .hero-visual img {
    width: 100%;
    height: 100%;
    min-height: 34rem;
    object-fit: cover;
  }

  .hero-note,
  .hero-service {
    position: absolute;
    backdrop-filter: blur(14px);
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(23, 48, 66, 0.08);
    box-shadow: 0 16px 40px rgba(24, 41, 53, 0.12);
  }

  .hero-note {
    left: 1.2rem;
    right: 5rem;
    bottom: 1.2rem;
    padding: 0.9rem 1rem;
    border-radius: 20px;
    color: #4b616b;
    font-size: 0.92rem;
  }

  .hero-note strong {
    display: block;
    margin-bottom: 0.2rem;
    color: #173042;
  }

  .hero-service {
    top: 1.2rem;
    right: -1.5rem;
    width: min(18rem, 82%);
    padding: 1rem 1.1rem;
    border-radius: 24px;
  }

  .hero-service-label {
    margin: 0 0 0.3rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7d5a2d;
  }

  .hero-service h2 {
    margin: 0;
    font-size: 1.15rem;
    color: #173042;
  }

  .hero-service p {
    margin: 0.55rem 0 0;
    color: #4b616b;
  }

  @media (max-width: 1080px) {
    .trust-list {
      grid-template-columns: 1fr;
    }

    .hero-shell {
      grid-template-columns: 1fr;
    }

    .hero-service {
      right: 1rem;
    }
  }

  @media (max-width: 720px) {
    .home-hero {
      padding-top: 1.8rem;
    }

    .hero-copy h1 {
      max-width: none;
    }

    .hero-visual img {
      min-height: 24rem;
    }

    .hero-note,
    .hero-service {
      position: static;
      width: auto;
      margin-top: 1rem;
    }
  }
</style>
