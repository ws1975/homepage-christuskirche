---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "./Hero.astro";

interface Props {
  entry: CollectionEntry<"pages"> | undefined;
}

const { entry } = Astro.props;

if (!entry) {
  throw new Error("MarkdownPage requires a valid entry.");
}

const { Content } = await render(entry);

const heroImageById: Record<string, string> = {
  gottesdienste: "/images/gottesdienst-raum.jpeg",
  livestream: "/images/gottesdienst.jpg",
  gemeindeleben: "/images/gemeinde.jpg",
  "kinder-familien": "/images/gemeinde.jpg",
  jugend: "/images/gemeinde.jpg",
  hauskreise: "/images/gemeinde.jpg",
  musik: "/images/gemeinde.jpg",
  senioren: "/images/gemeinde.jpg",
  "spenden-foerderung": "/images/gemeinde.jpg",
  "ueber-uns": "/images/gemeinde.jpg",
};

const heroCaptionById: Record<string, string> = {
  gottesdienste: "Gottendienstraum, Foto: Reinhard Weiß",
};

const heroAltById: Record<string, string> = {
  gottesdienste: "Gottesdienstraum der Kirche im Quadrat",
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  currentPath={Astro.url.pathname}
>
  <Hero
    eyebrow={entry.data.heroTag ?? "Gemeinde"}
    title={entry.data.title}
    text={entry.data.intro ?? entry.data.description}
    primaryLabel={entry.data.ctaLabel}
    primaryHref={entry.data.ctaHref}
    secondaryLabel="Alle Termine"
    secondaryHref="/termine/"
    image={heroImageById[entry.id] ?? "/images/hero.jpg"}
    imageAlt={heroAltById[entry.id] ?? "Blick in die Gemeinde"}
    imageCaption={heroCaptionById[entry.id]}
  />

  <section class="section">
    <div class="shell prose card">
      <Content />
    </div>
  </section>
</BaseLayout>
