---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "./Hero.astro";

interface Props {
  entry: CollectionEntry<"pages"> | undefined;
}

const { entry } = Astro.props;

if (!entry) {
  throw new Error("MarkdownPage requires a valid entry.");
}

const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  currentPath={Astro.url.pathname}
>
  <Hero
    eyebrow={entry.data.heroTag ?? "Gemeinde"}
    title={entry.data.title}
    text={entry.data.intro ?? entry.data.description}
    primaryLabel={entry.data.ctaLabel}
    primaryHref={entry.data.ctaHref}
    secondaryLabel="Alle Termine"
    secondaryHref="/termine/"
    image="/images/hero-sanctuary.svg"
  />

  <section class="section">
    <div class="shell prose card">
      <Content />
    </div>
  </section>
</BaseLayout>
