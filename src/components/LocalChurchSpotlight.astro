---
interface Props {
  title: string;
  address: string;
  phone: string;
  email: string;
  mapHref: string;
  image: string;
  imageAlt: string;
}

const { title, address, phone, email, mapHref, image, imageAlt } = Astro.props;
---

<section class="section">
  <div class="shell local-shell">
    <div class="local-copy">
      <p class="eyebrow">Kirche vor Ort</p>
      <h2>{title}</h2>
      <p>
        Die Christuskirche soll auf der Startseite nicht nur als Organisation,
        sondern als konkreter Ort sichtbar werden: ankommen, Orientierung bekommen,
        Route planen und Kontakt aufnehmen.
      </p>

      <div class="local-info">
        <div>
          <span>Adresse</span>
          <strong>{address}</strong>
        </div>
        <div>
          <span>Gottesdienst</span>
          <strong>Sonntag, 10:10 Uhr</strong>
        </div>
        <div>
          <span>Kontakt</span>
          <strong>
            <a href={`tel:${phone.replace(/\s+/g, "")}`}>{phone}</a>
            <br />
            <a href={`mailto:${email}`}>{email}</a>
          </strong>
        </div>
      </div>

      <div class="button-row">
        <a class="button button-primary" href={mapHref}>Route planen</a>
        <a class="button button-secondary" href="/kontakt/">Kontakt aufnehmen</a>
      </div>
    </div>

    <div class="local-visual">
      <div class="local-label">KIRCHE VOR ORT</div>
      <img src={image} alt={imageAlt} />
    </div>
  </div>
</section>

<style>
  .local-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 1.25rem;
    align-items: center;
  }

  .local-copy h2 {
    margin: 0;
    font-size: clamp(2.4rem, 4vw, 4.2rem);
    line-height: 0.98;
    color: #173042;
    max-width: 8ch;
  }

  .local-copy p {
    color: #5d7178;
    max-width: 36rem;
  }

  .local-info {
    display: grid;
    gap: 0.85rem;
    margin: 1.5rem 0;
  }

  .local-info div {
    padding: 1rem 1.1rem;
    border-radius: 20px;
    background: #ffffff;
    border: 1px solid rgba(23, 48, 66, 0.08);
    box-shadow: 0 14px 32px rgba(24, 41, 53, 0.05);
  }

  .local-info span {
    display: block;
    margin-bottom: 0.3rem;
    color: #7a6a57;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .local-info strong,
  .local-info a {
    color: #173042;
    text-decoration: none;
  }

  .local-visual {
    position: relative;
  }

  .local-label {
    position: absolute;
    left: -1rem;
    top: -1rem;
    z-index: 1;
    padding: 0.6rem 0.9rem;
    border-radius: 999px;
    background: #173042;
    color: white;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
  }

  .local-visual img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 30px;
    box-shadow: 0 24px 52px rgba(24, 41, 53, 0.12);
  }

  @media (max-width: 900px) {
    .local-shell {
      grid-template-columns: 1fr;
    }

    .local-copy h2 {
      max-width: none;
    }

    .local-label {
      left: 1rem;
      top: 1rem;
    }
  }
</style>
