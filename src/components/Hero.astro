---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  tertiaryLabel?: string;
  tertiaryHref?: string;
  image?: string;
  imageAlt?: string;
}

const {
  eyebrow,
  title,
  text,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  tertiaryLabel,
  tertiaryHref,
  image = "/images/hero.jpg",
  imageAlt = "Blick in die Gemeinde",
} = Astro.props;
---

<section class="hero">
  <div class="shell hero-grid">
    <div class="hero-visual">
      <img src={image} alt={imageAlt} />
    </div>

    <div class="hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="hero-text">{text}</p>
      <div class="button-row">
        {primaryLabel && primaryHref && (
          <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>
        )}
        {secondaryLabel && secondaryHref && (
          <a class="button button-secondary" href={secondaryHref}>
            {secondaryLabel}
          </a>
        )}
        {tertiaryLabel && tertiaryHref && (
          <a class="button button-secondary" href={tertiaryHref}>
            {tertiaryLabel}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 2rem 0 1rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 2rem;
    align-items: start;
  }

  .hero-visual {
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-soft);
    border: 1px solid var(--line);
  }

  .hero-visual img {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
  }

  .hero-copy {
    padding-top: 0.75rem;
  }

  .hero-copy h1 {
    margin: 0;
    font-size: clamp(2.5rem, 4.6vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--color-primary);
    font-weight: 500;
    max-width: 10ch;
  }

  .hero-text {
    max-width: 34ch;
    margin: 1rem 0 0;
    font-size: 1.08rem;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      padding-top: 0;
    }
  }
</style>
