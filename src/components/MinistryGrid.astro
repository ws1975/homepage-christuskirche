---
interface Item {
  title: string;
  href: string;
  text: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<section class="section">
  <div class="shell">
    <div class="section-head compact-head">
      <div>
        <p class="eyebrow">Gemeindeleben</p>
        <h2>Andocken, mitmachen, dazugehören</h2>
      </div>
      <a class="button button-secondary" href="/gemeindeleben/">Alle Bereiche</a>
    </div>

    <div class="ministry-grid">
      {
        items.map((item) => (
          <a class="ministry-card" href={item.href}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ministry-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .ministry-card {
    min-height: 13rem;
    padding: 1.4rem;
    border-radius: 26px;
    text-decoration: none;
    color: inherit;
    background:
      linear-gradient(180deg, rgba(23, 48, 66, 0.98), rgba(37, 74, 92, 0.96)),
      #173042;
    box-shadow: 0 18px 40px rgba(24, 41, 53, 0.1);
  }

  .ministry-card:nth-child(2n) {
    background:
      linear-gradient(180deg, rgba(110, 82, 41, 0.96), rgba(150, 112, 62, 0.94)),
      #6e5229;
  }

  .ministry-card h3 {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.08;
    color: white;
  }

  .ministry-card p {
    margin: 0.9rem 0 0;
    color: rgba(255, 255, 255, 0.82);
  }

  @media (max-width: 1100px) {
    .ministry-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .ministry-grid {
      grid-template-columns: 1fr;
    }

    .ministry-card {
      min-height: auto;
    }
  }
</style>
