---
import { mainNav, quickLinks, site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = site.title,
  description = site.description,
  currentPath = Astro.url.pathname,
} = Astro.props;

const pageTitle =
  title === site.title ? site.title : `${title} | ${site.title}`;

const footerSocials = [
  { label: "YouTube", href: site.livestreamUrl },
  { label: "Instagram", href: site.instagramUrl || undefined },
];

const footerLegal = [
  { label: "Datenschutz", href: undefined },
  { label: "Impressum", href: undefined },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    <header class="site-header">
      <div class="shell header-row">
        <a class="brand" href="/">
          <img
            class="brand-logo"
            src="/images/logo.svg"
            alt="Christuskirche Lörrach"
          />
          <span class="brand-copy">
            <strong>{site.name}</strong>
            <small>gemeinsam Gott begegnen</small>
          </span>
        </a>

        <nav aria-label="Hauptnavigation">
          <ul class="main-nav">
            {
              mainNav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={currentPath === item.href ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main id="inhalt">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell footer-grid">
        <div>
          <h2>{site.name}</h2>
          <p>
            Ein ruhiger, freundlicher Ort für Gottesdienst, Begegnung und
            Gemeindeleben in Lörrach.
          </p>
        </div>

        <div>
          <h2>Schnellzugriff</h2>
          <ul class="footer-links">
            {
              [...mainNav, ...quickLinks].map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
              ))
            }
          </ul>
        </div>

        <div>
          <h2>Kontakt</h2>
          <p>{site.address}</p>
          <p>
            <a href={`tel:${site.phone.replace(/\s+/g, "")}`}>{site.phone}</a>
          </p>
          <p>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </p>
        </div>

        <div>
          <h2>Mehr</h2>
          <ul class="footer-links">
            {
              footerSocials.map((item) => (
                <li>
                  {item.href ? (
                    <a href={item.href}>{item.label}</a>
                  ) : (
                    <span>{item.label} folgt</span>
                  )}
                </li>
              ))
            }
            {
              footerLegal.map((item) => (
                <li>
                  {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label} offen</span>}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #0f6f95;
    --color-primary-dark: #0a5878;
    --color-accent: #a7c84a;
    --color-background: #fbfcfb;
    --color-text: #24495d;
    --color-muted: #6b7e87;
    --color-border: rgba(38, 73, 93, 0.18);
    --color-soft: #f4f7f7;
    --color-soft-alt: #eef4f3;
    --shadow-soft: 0 14px 34px rgba(36, 73, 93, 0.07);
    --radius: 18px;
    --radius-sm: 10px;
    --shell: 1180px;
    --bg: var(--color-background);
    --surface: #ffffff;
    --surface-alt: var(--color-soft);
    --surface-strong: var(--color-primary-dark);
    --text: var(--color-text);
    --muted: var(--color-muted);
    --line: var(--color-border);
    --brand: var(--color-primary);
    --brand-strong: var(--color-primary-dark);
    --accent: var(--color-accent);
    --shadow: var(--shadow-soft);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: "Trebuchet MS", "Helvetica Neue", Arial, sans-serif;
    color: var(--text);
    background: var(--color-background);
    line-height: 1.65;
  }

  a {
    color: inherit;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: -3rem;
    background: var(--color-primary-dark);
    color: white;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    z-index: 100;
  }

  .skip-link:focus {
    top: 1rem;
  }

  .shell {
    width: min(calc(100% - 2rem), var(--shell));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.97);
    border-bottom: 1px solid var(--line);
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0 0.95rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    min-width: 0;
  }

  .brand-logo {
    width: 52px;
    height: 52px;
    object-fit: contain;
    flex: 0 0 auto;
  }

  .brand-copy strong {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-primary-dark);
  }

  .brand-copy small {
    display: block;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .main-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .main-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.15rem 0;
    text-decoration: none;
    color: var(--color-primary);
    border-bottom: 2px solid transparent;
    font-size: 1.05rem;
    font-weight: 500;
  }

  .main-nav a[aria-current="page"],
  .main-nav a:hover,
  .main-nav a:focus-visible {
    color: var(--color-primary-dark);
    border-color: var(--color-accent);
    outline: none;
  }

  .site-footer {
    margin-top: 5rem;
    padding: 3rem 0 4rem;
    background: #f5f8f8;
    border-top: 1px solid var(--line);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .site-footer h2 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    color: var(--color-primary-dark);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li + li {
    margin-top: 0.35rem;
  }

  .footer-links span {
    color: var(--muted);
  }

  .section {
    padding: 4rem 0;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.75rem 1.1rem;
    border-radius: 4px;
    border: 1px solid transparent;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.98rem;
  }

  .button-primary {
    background: var(--color-primary);
    color: white;
  }

  .button-primary:hover,
  .button-primary:focus-visible {
    background: var(--color-primary-dark);
  }

  .button-secondary {
    background: white;
    border-color: var(--line);
    color: var(--color-primary-dark);
  }

  .button-secondary:hover,
  .button-secondary:focus-visible {
    border-color: var(--color-accent);
    background: var(--color-soft);
    outline: none;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
  }

  .meta {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .prose {
    max-width: 72ch;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2rem;
    color: var(--color-primary-dark);
    font-weight: 600;
  }

  .prose a {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .header-row,
    .section-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .main-nav {
      gap: 0.8rem 1rem;
    }

    .footer-grid,
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
