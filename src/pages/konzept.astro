---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Konzept" currentPath={Astro.url.pathname}>
  <section class="section">
    <div class="shell concept-hero">
      <div>
        <p class="eyebrow">Workshop-Demo</p>
        <h1>Wie die neue Homepage gedacht ist</h1>
        <p class="lead">
          Diese Seite erklärt den Kern der Demo: einfacher als die bisherige
          Website, pflegbar ohne klassisches CMS und vorbereitet auf einen
          künftigen KI-gestützten Flyer-Import.
        </p>
      </div>
      <div class="button-row">
        <a class="button button-primary" href="/termine/">Termine ansehen</a>
        <a class="button button-secondary" href="/">Zur Startseite</a>
      </div>
    </div>
  </section>

  <section class="section section-compact">
    <div class="shell card-grid">
      <article class="card">
        <p class="eyebrow">Warum neue Homepage?</p>
        <h2>Weniger Wege, weniger Dopplungen</h2>
        <p>
          Die bisherige Website verteilt ähnliche Inhalte auf viele Bereiche.
          Die Demo reduziert das auf wenige klare Einstiege für Erstbesucher:
          Gottesdienst, Gemeindeleben, Lebensstationen und Kontakt.
        </p>
      </article>

      <article class="card">
        <p class="eyebrow">Warum ohne CMS?</p>
        <h2>Weniger technische Last</h2>
        <p>
          Für eine überschaubare Gemeindeseite sind Datenbank, Login und
          komplexe Redaktionsoberfläche oft mehr Ballast als Hilfe. Markdown und
          strukturierte Dateien reichen hier aus.
        </p>
      </article>

      <article class="card">
        <p class="eyebrow">Wie funktioniert Pflege?</p>
        <h2>Dateien statt Masken</h2>
        <p>
          Seiten liegen als Markdown unter <code>src/content/pages/</code>,
          Termine unter <code>src/content/events/</code>. Änderungen werden per
          Git versioniert und statisch veröffentlicht.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="shell process-band">
      <div>
        <p class="eyebrow">Flyer-Prozess</p>
        <h2>Flyer → KI → Event-Datei → Homepage</h2>
        <p class="lead">
          Der Flyer bleibt Eingangsdokument. Die Website selbst soll aber aus
          strukturierten Event-Daten aufgebaut werden.
        </p>
      </div>

      <div class="process-grid">
        <article class="step-card">
          <strong>1</strong>
          <h3>Flyer ablegen</h3>
          <p>PDF oder Bild kommt in den Ordner <code>flyer-input/</code>.</p>
        </article>

        <article class="step-card">
          <strong>2</strong>
          <h3>KI liest Inhalte aus</h3>
          <p>
            Codex oder ein anderes OCR-/KI-Werkzeug extrahiert Titel, Datum,
            Ort, Beschreibung und Kategorie.
          </p>
        </article>

        <article class="step-card">
          <strong>3</strong>
          <h3>Event-Datei entsteht</h3>
          <p>
            Daraus wird eine Datei in <code>src/content/events/</code> mit
            festen Feldern erzeugt.
          </p>
        </article>

        <article class="step-card">
          <strong>4</strong>
          <h3>Homepage aktualisiert sich</h3>
          <p>
            Startseite und <code>/termine/</code> ziehen die Daten automatisch
            aus derselben Datei.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-compact">
    <div class="shell workshop-note card">
      <p class="eyebrow">Für den Workshop wichtig</p>
      <h2>Was diese Demo bewusst nicht braucht</h2>
      <ul>
        <li>keine Datenbank</li>
        <li>kein Login</li>
        <li>kein externes CMS</li>
        <li>keine direkte Anbindung an LUKAS oder EDITH</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.6rem);
  }

  .lead {
    max-width: 62ch;
    color: var(--muted);
  }

  .concept-hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-compact {
    padding-top: 0;
  }

  .process-band {
    padding: 2rem;
    border-radius: 32px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(244, 236, 223, 0.96));
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .step-card {
    padding: 1.25rem;
    border-radius: 22px;
    background: var(--surface);
    border: 1px solid var(--line);
  }

  .step-card strong {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--brand);
    color: white;
  }

  .step-card h3 {
    margin: 0.9rem 0 0.4rem;
  }

  .workshop-note ul {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
  }

  @media (max-width: 900px) {
    .process-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
