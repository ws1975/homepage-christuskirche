---
import BaseLayout from "../layouts/BaseLayout.astro";
import CommunityHighlights from "../components/CommunityHighlights.astro";
import FloatingContact from "../components/FloatingContact.astro";
import HomeHero from "../components/HomeHero.astro";
import LocalChurchSpotlight from "../components/LocalChurchSpotlight.astro";
import MinistryGrid from "../components/MinistryGrid.astro";
import NextServiceSpotlight from "../components/NextServiceSpotlight.astro";
import VisitorIntentGrid from "../components/VisitorIntentGrid.astro";
import WeeklyVideoFeature from "../components/WeeklyVideoFeature.astro";
import { site } from "../data/site";
import { formatEventDate, getFeaturedEvents, getUpcomingServices } from "../lib/events";

const services = await getUpcomingServices(1);
const highlights = await getFeaturedEvents(4);
const nextService = services[0];
const mapHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.address)}`;

const visitorIntents = [
  {
    title: "Ich suche einen Gottesdienst",
    text: "Zeiten, Ablauf, Kindergottesdienst und der direkte Weg zum nächsten Sonntag.",
    href: "/gottesdienste/",
  },
  {
    title: "Ich brauche Hilfe oder Seelsorge",
    text: "Kontakt zum Gemeindebüro und ein klarer Einstieg für persönliche Anliegen.",
    href: "/kontakt/",
  },
  {
    title: "Ich möchte die Gemeinde kennenlernen",
    text: "Wer wir sind, wie wir leben und wo man unkompliziert andocken kann.",
    href: "/ueber-uns/",
  },
];

const imageByCategory = {
  Gottesdienst: "/images/gottesdienst-raum.jpeg",
  Gemeindeleben: "/images/gemeinde.jpg",
  Jugend: "/images/hero-community.svg",
  "Kinder/Familien": "/images/hero-community.svg",
  Musik: "/images/hero-events.svg",
  Extern: "/images/hero-sanctuary.svg",
};

const highlightItems = highlights.map((event) => ({
  title: event.data.title,
  text: event.data.description,
  meta: `${event.data.category} · ${formatEventDate(event.data.start)}`,
  href:
    event.data.category === "Gottesdienst"
      ? "/gottesdienste/"
      : event.data.category === "Jugend"
        ? "/jugend/"
        : event.data.category === "Kinder/Familien"
          ? "/kinder-familien/"
          : "/termine/",
  image: imageByCategory[event.data.category],
  imageAlt: `Platzhalterbild für ${event.data.category} in der Christuskirche`,
}));

const ministryItems = [
  {
    title: "Kinder",
    text: "Kindergottesdienst, Familienangebote und erste Anknüpfungspunkte.",
    href: "/kinder-familien/",
  },
  {
    title: "Jugend",
    text: "Offene Treffen, Soulfood und Raum für Glaubensfragen.",
    href: "/jugend/",
  },
  {
    title: "Hauskreise",
    text: "Glauben im Alltag teilen, Gespräch vertiefen und Gemeinschaft erleben.",
    href: "/hauskreise/",
  },
  {
    title: "Musik",
    text: "Mitgestalten, begleiten und Gottesdienste klanglich prägen.",
    href: "/musik/",
  },
  {
    title: "Gebet",
    text: "Ruhige Formate wie 'Vor Dir' und persönliche geistliche Begleitung.",
    href: "/gottesdienste/",
  },
  {
    title: "Senioren",
    text: "Begegnung, Austausch und verlässliche Gemeinschaft im Alltag.",
    href: "/senioren/",
  },
  {
    title: "Mitarbeit",
    text: "Vom Willkommensteam bis zur Technik gibt es konkrete Möglichkeiten mitzumachen.",
    href: "/gemeindeleben/",
  },
  {
    title: "Mission",
    text: "Glaube sichtbar leben, Menschen einladen und Verantwortung übernehmen.",
    href: "/gemeindeleben/",
  },
];
---

<BaseLayout
  title="Start"
  description="Prototyp einer besucherorientierten Startseite der Christuskirche Lörrach mit klaren Einstiegen, Gottesdienst-Spotlight und lokalem Kontakt."
  currentPath={Astro.url.pathname}
>
  <FloatingContact phone={site.phone} email={site.email} mapHref={mapHref} />

  <HomeHero
    title={"Willkommen\nin der Kirchengemeinde\nLörrach"}
    subtitle="Gemeinsam glauben. Gemeinsam leben."
    text="Diese Startseite denkt nicht zuerst in Rubriken, sondern in Anliegen. Besucher sollen in wenigen Sekunden erkennen, wo sie sonntags ankommen, wie sie Hilfe finden und wie sie die Gemeinde kennenlernen können."
    primaryLabel="Mehr erfahren"
    primaryHref="/ueber-uns/"
    secondaryLabel="Gottesdienst besuchen"
    secondaryHref="/gottesdienste/"
    image="/images/gottesdienst-raum.jpeg"
    imageAlt="Innenraum der Christuskirche als Platzhalter für einen späteren Hero mit echten Menschen"
    nextService={nextService}
  />

  <VisitorIntentGrid items={visitorIntents} />

  <NextServiceSpotlight service={nextService} />

  <CommunityHighlights items={highlightItems} />

  <WeeklyVideoFeature
    title="Predigt der Woche: Glauben im Alltag leben"
    text="Prominent, einfach und medial klar: Hier bekommt die Startseite einen festen Ort für Predigt, Video oder Wochenimpuls. Im finalen Stand sollte dieses Element redaktionell gepflegt oder aus dem Livestream-Kontext gespeist werden."
    href={site.livestreamUrl}
    image="/images/gottesdienst-raum.jpeg"
    imageAlt="Videovorschaubild als Platzhalter für Predigt oder Wochenvideo"
  />

  <LocalChurchSpotlight
    title="Kirche vor Ort"
    address={site.address}
    phone={site.phone}
    email={site.email}
    mapHref={mapHref}
    image="/images/gottesdienst-raum.jpeg"
    imageAlt="Innenraum der Kirche als Platzhalter für Foto der Christuskirche vor Ort"
  />

  <MinistryGrid items={ministryItems} />
</BaseLayout>

<style>
  :global(body) {
    background:
      linear-gradient(180deg, #fcfbf8 0%, #f7f3ed 38%, #fbfcfb 100%);
  }

  :global(.site-header) {
    background: rgba(252, 251, 248, 0.92);
    backdrop-filter: blur(14px);
  }

  :global(.brand-copy strong) {
    font-family: "Avenir Next", "Segoe UI", sans-serif;
    letter-spacing: 0;
  }

  :global(.main-nav a) {
    color: #315264;
  }

  :global(.site-footer) {
    margin-top: 3rem;
  }
</style>
