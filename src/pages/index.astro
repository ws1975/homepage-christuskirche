---
import BaseLayout from "../layouts/BaseLayout.astro";
import EventCard from "../components/EventCard.astro";
import Hero from "../components/Hero.astro";
import { site } from "../data/site";
import { getHomepageEvents, getUpcomingServices } from "../lib/events";

const services = await getUpcomingServices(2);
const events = await getHomepageEvents(4);
---

<BaseLayout title="Start" currentPath={Astro.url.pathname}>
  <Hero
    title="Willkommen in der Christuskirche Lörrach"
    text="Gemeinsam Gott begegnen. Menschen willkommen heißen. Glauben leben."
    primaryLabel="Gottesdienst besuchen"
    primaryHref="/gottesdienste/"
    secondaryLabel="Nächste Termine"
    secondaryHref="/termine/"
    tertiaryLabel="Kontakt aufnehmen"
    tertiaryHref="/kontakt/"
    image="/images/hero.jpg"
    imageAlt="Blühender Kirchenhof der Christuskirche"
  />

  <section class="section">
    <div class="shell two-col">
      <article class="card">
        <p class="eyebrow">Neu hier?</p>
        <h2>Ein guter erster Schritt</h2>
        <p>
          Wenn Sie die Christuskirche zum ersten Mal besuchen, finden Sie hier
          schnell die wichtigsten Informationen: Gottesdienstzeiten, Hinweise
          für Kinder, Livestream und Kontakt.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="/gottesdienste/">
            Gottesdienst besuchen
          </a>
          <a class="button button-secondary" href="/kontakt/">Kontakt aufnehmen</a>
        </div>
      </article>

      <article class="arrival-card">
        <p class="eyebrow">Kurz gesagt</p>
        <h2>Sonntag, Begegnung, Alltag und Glauben</h2>
        <p>
          Wir feiern Gottesdienst, begleiten Menschen in verschiedenen
          Lebensphasen und gestalten Gemeindeleben für Kinder, Jugendliche,
          Familien, Erwachsene und Seniorinnen und Senioren.
        </p>
        <ul>
          <li>Gottesdienst und Kindergottesdienst</li>
          <li>Gruppen, Musik und Hauskreise</li>
          <li>offene Kontakt- und Begleitungsangebote</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="shell event-spotlight">
      <div class="section-head">
        <div>
          <p class="eyebrow">Nächste Gottesdienste und Termine</p>
          <h2>Was als Nächstes ansteht</h2>
          <p class="lead">
            Die kommenden Termine werden automatisch aus den Event-Dateien
            erzeugt. Gottesdienste stehen dabei besonders im Vordergrund.
          </p>
        </div>
        <a class="button button-primary" href="/termine/">Alle Termine</a>
      </div>

      <div class="service-grid">
        {services.map((event) => <EventCard event={event} />)}
      </div>

      <div class="card-grid compact-grid">
        {events.map((event) => <EventCard event={event} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell feature-band">
      <div class="feature-copy">
        <p class="eyebrow">Gemeindeleben</p>
        <h2>Räume für Begegnung und Glauben im Alltag</h2>
        <p>
          Zwischen Sonntag und Alltag gibt es viele Möglichkeiten zum Andocken:
          für Kinder und Familien, Jugendliche, Musikbegeisterte, Hauskreise
          und offene Treffpunkte.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="/gemeindeleben/">Gemeindeleben entdecken</a>
          <a class="button button-secondary" href="/kinder-familien/">Kinder & Familien</a>
          <a class="button button-secondary" href="/jugend/">Jugend</a>
        </div>
      </div>

      <div class="feature-image">
        <img
          src="/images/gemeinde.jpg"
          alt="Gemeindeleben in der Christuskirche"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell two-col">
      <article class="card">
        <p class="eyebrow">Livestream</p>
        <h2>Online mitfeiern</h2>
        <p>
          Wenn ein Gottesdienst übertragen wird, finden Sie die Hinweise und den
          Zugang gesammelt auf der Livestream-Seite.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="/livestream/">Zum Livestream</a>
          <a class="button button-secondary" href={site.livestreamUrl}>YouTube-Kanal</a>
        </div>
      </article>

      <article class="card">
        <p class="eyebrow">Kontakt & Anfahrt</p>
        <h2>Gut erreichbar in Lörrach</h2>
        <p>
          Christuskirche Lörrach, {site.address}. Das Gemeindebüro ist unter
          {site.phone} und {site.email} erreichbar.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="/kontakt/">Kontakt & Anfahrt</a>
          <a class="button button-secondary" href="/spenden-foerderung/">Spenden & Förderung</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: 1.05;
  }

  .lead {
    max-width: 60ch;
    color: var(--muted);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .arrival-card {
    padding: 1.75rem;
    border-radius: 18px;
    background: linear-gradient(180deg, #f4f9fa, #edf4f4);
    color: var(--text);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .arrival-card .eyebrow,
  .arrival-card h2,
  .arrival-card p,
  .arrival-card li {
    color: inherit;
  }

  .arrival-card ul {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
  }

  .event-spotlight {
    padding: 2rem;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #f9fbfb);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .service-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin: 0 0 1.5rem;
  }

  .compact-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .feature-band {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 2rem;
    align-items: center;
    padding: 2rem;
    border-radius: 18px;
    background: linear-gradient(120deg, #ffffff, #f6f9f9);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .feature-image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 12px;
  }

  @media (max-width: 900px) {
    .two-col,
    .service-grid,
    .compact-grid,
    .feature-band {
      grid-template-columns: 1fr;
    }
  }
</style>
